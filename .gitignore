*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
id_rsa
id_dsa
id_ecdsa
id_ed25519
gha-creds-*.json
credentials*.json
service-account*.json
application_default_credentials.json
.netrc
.npmrc
.pypirc
